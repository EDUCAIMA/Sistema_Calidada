generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  logo         String?
  industry     String?
  timezone     String?       @default("America/Bogota")
  currency     String?       @default("USD")
  phone        String?
  plan         PlanType      @default(BASICO)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  audits       Audit[]
  dofaItems    DOFAItem[]
  documents    Document[]
  processes    Process[]
  risks        Risk[]
  riskMatrices RiskMatrix[]
  sgcScopes    SGCScope[]
  stakeholders Stakeholder[]
  users        User[]
  formatControls FormatControl[]
}

model User {
  id                   String    @id @default(cuid())
  tenantId             String
  email                String    @unique
  password             String?
  name                 String
  position             String?
  phone                String?
  role                 Role      @default(USUARIO)
  avatar               String?
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  processesResponsible Process[] @relation("ProcessResponsible")
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
}

model Process {
  id               String                   @id @default(cuid())
  tenantId         String
  name             String
  code             String
  category         ProcessCategory
  objective        String
  scope            String
  responsibleId    String
  responsibleName  String?
  order            Int
  active           Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  documents        Document[]
  responsible      User                     @relation("ProcessResponsible", fields: [responsibleId], references: [id])
  tenant           Tenant                   @relation(fields: [tenantId], references: [id])
  characterization ProcessCharacterization?
  risks            Risk[]
}

model ProcessCharacterization {
  id         String   @id @default(cuid())
  processId  String   @unique
  version    String
  date       String
  planear    Json
  hacer      Json
  verificar  Json
  actuar     Json
  resources  Json
  indicators Json
  documents  Json
  risks      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  process    Process  @relation(fields: [processId], references: [id])
}

model Document {
  id             String            @id @default(cuid())
  tenantId       String
  code           String
  name           String
  type           DocumentType
  status         DocumentStatus    @default(BORRADOR)
  processId      String?
  processName    String?
  currentVersion Int               @default(1)
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  createdBy      String
  createdByName  String?
  approvedBy     String?
  approvedDate   DateTime?
  nextReviewDate DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  process        Process?          @relation(fields: [processId], references: [id])
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  versions       DocumentVersion[]
}

model DocumentVersion {
  id                String   @id @default(cuid())
  documentId        String
  version           Int
  changeDescription String
  fileUrl           String
  fileName          String
  uploadedBy        String
  uploadedByName    String?
  uploadedAt        DateTime @default(now())
  document          Document @relation(fields: [documentId], references: [id])
}

model RiskMatrix {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        RiskType
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  risks       Risk[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Risk {
  id                  String       @id @default(cuid())
  tenantId            String
  matrixId            String
  processId           String?
  processName         String?
  description         String
  type                RiskType
  cause               String
  consequence         String
  probability         Int
  impact              Int
  level               RiskLevel
  riskValue           Int
  existingControls    String
  treatmentPlan       String
  responsible         String
  dueDate             DateTime?
  status              ActionStatus @default(ABIERTA)
  residualProbability Int?
  residualImpact      Int?
  residualLevel       RiskLevel?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  matrix              RiskMatrix   @relation(fields: [matrixId], references: [id])
  process             Process?     @relation(fields: [processId], references: [id])
  tenant              Tenant       @relation(fields: [tenantId], references: [id])
}

model Audit {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  type            String
  status          AuditStatus @default(PROGRAMADA)
  leadAuditor     String
  leadAuditorName String?
  processes       Json
  scheduledDate   DateTime
  completionDate  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  findings        Finding[]
}

model Finding {
  id               String            @id @default(cuid())
  auditId          String
  type             FindingType
  clause           String
  processId        String?
  description      String
  evidence         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  correctiveAction CorrectiveAction?
  audit            Audit             @relation(fields: [auditId], references: [id])
}

model CorrectiveAction {
  id          String       @id @default(cuid())
  findingId   String       @unique
  description String
  responsible String
  dueDate     DateTime
  status      ActionStatus @default(ABIERTA)
  evidence    String?
  closedDate  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  finding     Finding      @relation(fields: [findingId], references: [id])
}

model DOFAItem {
  id          String       @id @default(cuid())
  tenantId    String
  category    DOFACategory
  description String
  impact      String?
  actions     String?
  responsible String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
}

model Stakeholder {
  id           String               @id @default(cuid())
  tenantId     String
  name         String
  type         StakeholderType
  needs        String
  expectations String
  influence    StakeholderInfluence
  strategy     String
  contactInfo  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  tenant       Tenant               @relation(fields: [tenantId], references: [id])
}

model SGCScope {
  id                  String   @id @default(cuid())
  tenantId            String
  scopeStatement      String
  applicableStandards Json
  exclusions          Json
  sites               Json
  processes           Json
  lastReviewDate      DateTime
  approvedBy          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
}

model FormatControl {
  id           String   @id @default(cuid())
  tenantId     String
  moduleKey    String
  code         String
  version      String
  approvalDate String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, moduleKey])
}

enum Role {
  SUPER_ADMIN
  ADMIN_EMPRESA
  USUARIO
  AUDITOR_INTERNO
  AUDITOR_EXTERNO
}

enum DocumentStatus {
  BORRADOR
  EN_REVISION
  APROBADO
  OBSOLETO
}

enum DocumentType {
  MANUAL
  PROCEDIMIENTO
  INSTRUCTIVO
  FORMATO
  POLITICA
  GUIA
  REGISTRO
  OTRO
}

enum ProcessCategory {
  ESTRATEGICO
  MISIONAL
  APOYO
  EVALUACION
}

enum RiskType {
  OPERACIONAL
  CALIDAD
  SST
  AMBIENTAL
  OTRO
}

enum RiskLevel {
  BAJO
  MEDIO
  ALTO
  CRITICO
}

enum AuditStatus {
  PROGRAMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum FindingType {
  NC_MAYOR
  NC_MENOR
  OBSERVACION
  OPORTUNIDAD_MEJORA
}

enum ActionStatus {
  ABIERTA
  EN_PROGRESO
  CERRADA
  VENCIDA
}

enum PlanType {
  BASICO
  PROFESIONAL
  ENTERPRISE
}

enum DOFACategory {
  DEBILIDAD
  OPORTUNIDAD
  FORTALEZA
  AMENAZA
}

enum StakeholderType {
  INTERNO
  EXTERNO
}

enum StakeholderInfluence {
  ALTA
  MEDIA
  BAJA
}

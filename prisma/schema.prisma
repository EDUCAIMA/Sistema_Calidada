generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  logo           String?
  plan           PlanType        @default(BASICO)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  currency       String?         @default("USD")
  industry       String?
  phone          String?
  timezone       String?         @default("America/Bogota")
  audits         Audit[]
  dofaItems      DOFAItem[]
  documents      Document[]
  formatControls FormatControl[]
  policies       Policy[]
  processes      Process[]
  risks          Risk[]
  riskMatrices   RiskMatrix[]
  sgcScopes      SGCScope[]
  stakeholders   Stakeholder[]
  users          User[]
  qualityObjectives QualityObjective[]
}

model User {
  id                   String    @id @default(cuid())
  tenantId             String
  email                String    @unique
  password             String?
  name                 String
  position             String?
  role                 Role      @default(USUARIO)
  avatar               String?
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  phone                String?
  processesResponsible Process[] @relation("ProcessResponsible")
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
}

model Process {
  id               String                   @id @default(cuid())
  tenantId         String
  name             String
  code             String
  category         ProcessCategory
  objective        String
  scope            String
  responsibleId    String
  responsibleName  String?
  order            Int
  active           Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  documents        Document[]
  responsible      User                     @relation("ProcessResponsible", fields: [responsibleId], references: [id])
  tenant           Tenant                   @relation(fields: [tenantId], references: [id])
  characterization ProcessCharacterization?
  risks            Risk[]
}

model ProcessCharacterization {
  id         String   @id @default(cuid())
  processId  String   @unique
  version    String
  date       String
  planear    Json
  hacer      Json
  verificar  Json
  actuar     Json
  resources  Json
  indicators Json
  documents  Json
  risks      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  process    Process  @relation(fields: [processId], references: [id])
}

model Document {
  id             String            @id @default(cuid())
  tenantId       String
  code           String
  name           String
  type           DocumentType
  status         DocumentStatus    @default(BORRADOR)
  processId      String?
  processName    String?
  currentVersion Int               @default(1)
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  createdBy      String
  createdByName  String?
  approvedBy     String?
  approvedDate   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  nextReviewDate DateTime?
  process        Process?          @relation(fields: [processId], references: [id])
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  versions       DocumentVersion[]
}

model DocumentVersion {
  id                String   @id @default(cuid())
  documentId        String
  version           Int
  changeDescription String
  fileUrl           String
  fileName          String
  uploadedBy        String
  uploadedByName    String?
  uploadedAt        DateTime @default(now())
  document          Document @relation(fields: [documentId], references: [id])
}

model RiskMatrix {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        RiskType
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  risks       Risk[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Risk {
  id                  String       @id @default(cuid())
  tenantId            String
  matrixId            String
  processId           String?
  processName         String?
  description         String
  type                RiskType
  cause               String
  consequence         String
  probability         Int
  impact              Int
  level               RiskLevel
  riskValue           Int
  existingControls    String
  treatmentPlan       String
  responsible         String
  dueDate             DateTime?
  status              ActionStatus @default(ABIERTA)
  residualProbability Int?
  residualImpact      Int?
  residualLevel       RiskLevel?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  matrix              RiskMatrix   @relation(fields: [matrixId], references: [id])
  process             Process?     @relation(fields: [processId], references: [id])
  tenant              Tenant       @relation(fields: [tenantId], references: [id])
}

model Audit {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  type            String
  status          AuditStatus @default(PROGRAMADA)
  leadAuditor     String
  leadAuditorName String?
  processes       Json
  scheduledDate   DateTime
  completionDate  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  findings        Finding[]
}

model Finding {
  id               String            @id @default(cuid())
  auditId          String
  type             FindingType
  clause           String
  processId        String?
  description      String
  evidence         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  correctiveAction CorrectiveAction?
  audit            Audit             @relation(fields: [auditId], references: [id])
}

model CorrectiveAction {
  id          String       @id @default(cuid())
  findingId   String       @unique
  description String
  responsible String
  dueDate     DateTime
  status      ActionStatus @default(ABIERTA)
  evidence    String?
  closedDate  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  finding     Finding      @relation(fields: [findingId], references: [id])
}

model DOFAItem {
  id          String       @id @default(cuid())
  tenantId    String
  category    DOFACategory
  description String
  impact      String?
  actions     String?
  responsible String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
}

model Stakeholder {
  id           String               @id @default(cuid())
  tenantId     String
  name         String
  type         StakeholderType
  needs        String
  expectations String
  influence    StakeholderInfluence
  strategy     String
  contactInfo  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  tenant       Tenant               @relation(fields: [tenantId], references: [id])
}

model SGCScope {
  id                  String   @id @default(cuid())
  tenantId            String
  scopeStatement      String
  applicableStandards Json
  exclusions          Json
  sites               Json
  processes           Json
  lastReviewDate      DateTime
  approvedBy          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
}

model FormatControl {
  id           String   @id @default(cuid())
  tenantId     String
  moduleKey    String
  code         String
  version      String
  approvalDate String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleKey])
}

model Policy {
  id             String                @id @default(cuid())
  tenantId       String
  title          String
  content        String
  type           String                @default("General")
  version        String                @default("1.0")
  status         PolicyStatus          @default(EN_REVISION)
  author         String
  objectives     Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  communications PolicyCommunication[]
}

model PolicyCommunication {
  id              String   @id @default(cuid())
  policyId        String
  audience        String
  method          String
  date            DateTime
  evidence        String?
  responsibleName String
  notes           String?
  createdAt       DateTime @default(now())
  policy          Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  ADMIN_EMPRESA
  USUARIO
  AUDITOR_INTERNO
  AUDITOR_EXTERNO
}

enum DocumentStatus {
  BORRADOR
  EN_REVISION
  APROBADO
  OBSOLETO
}

enum DocumentType {
  MANUAL
  PROCEDIMIENTO
  INSTRUCTIVO
  FORMATO
  POLITICA
  REGISTRO
  OTRO
  GUIA
}

enum ProcessCategory {
  ESTRATEGICO
  MISIONAL
  APOYO
  EVALUACION
}

enum RiskType {
  OPERACIONAL
  CALIDAD
  SST
  AMBIENTAL
  OTRO
}

enum RiskLevel {
  BAJO
  MEDIO
  ALTO
  CRITICO
}

enum AuditStatus {
  PROGRAMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum FindingType {
  NC_MAYOR
  NC_MENOR
  OBSERVACION
  OPORTUNIDAD_MEJORA
}

enum ActionStatus {
  ABIERTA
  EN_PROGRESO
  CERRADA
  VENCIDA
}

enum PlanType {
  BASICO
  PROFESIONAL
  ENTERPRISE
}

enum PolicyStatus {
  VIGENTE
  EN_REVISION
  OBSOLETA
}

enum DOFACategory {
  DEBILIDAD
  OPORTUNIDAD
  FORTALEZA
  AMENAZA
}

enum StakeholderType {
  INTERNO
  EXTERNO
}

enum StakeholderInfluence {
  ALTA
  MEDIA
  BAJA
}

model QualityObjective {
  id              String   @id @default(cuid())
  tenantId        String
  description     String   // ¿Qué se va a hacer?
  indicator       String   // ¿Cómo se medirá?
  target          String   // Meta
  actual          String?  // Valor actual
  resources       String?  // ¿Qué recursos se necesitarán?
  responsibleId   String?  // ¿Quién será responsable?
  responsibleName String?
  deadline        DateTime // ¿Cuándo se finalizará?
  evaluationFreq  String?  // ¿Cómo se evaluarán los resultados?
  status          String   @default("EN_PROGRESO") // EN_PROGRESO, CUMPLIDO, NO_CUMPLIDO
  progress        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  tracking        ObjectiveTracking[]
}

model ObjectiveTracking {
  id          String   @id @default(cuid())
  objectiveId String
  date        DateTime @default(now())
  note        String
  progress    Int
  objective   QualityObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
}

